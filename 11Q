frase = input("Digite uma frase: ").lower()

contagem = {}

for letra in frase:
    if letra.isalpha():
        if letra in contagem:
            contagem[letra] += 1
        else:
            contagem[letra] = 1
            
            
print("Frequencia de letras: ")
for letra, qtd in contagem.items():
    print(f"{letra}: {qtd}x")
